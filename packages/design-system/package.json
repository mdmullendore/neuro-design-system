{
  "name": "@neuro/design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": ["dist"],
  "exports": {
    "./neurons/*": {
      "types": "./dist/neurons/*/index.d.ts",
      "import": "./dist/neurons/*/index.js"
    },
    "./synapses/*": {
      "types": "./dist/synapses/*/index.d.ts",
      "import": "./dist/synapses/*/index.js"
    },
    "./circuits/*": {
      "types": "./dist/circuits/*/index.d.ts",
      "import": "./dist/circuits/*/index.js"
    },
    "./pathways/*": {
      "types": "./dist/pathways/*/index.d.ts",
      "import": "./dist/pathways/*/index.js"
    },
    "./cortex/*": {
      "types": "./dist/cortex/*/index.d.ts",
      "import": "./dist/cortex/*/index.js"
    },
    "./neurotransmitters/index.scss": "./dist/neurotransmitters/index.scss",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:tokens": "node --experimental-strip-types src/tokens/generate-scss.ts",
    "build:js": "tsc -p tsconfig.build.json",
    "build:scss": "node scripts/copy-scss.mjs",
    "build": "npm run clean && npm run build:tokens && npm run build:js && npm run build:scss"
  },
  "devDependencies": {
    "react-native": "^0.86.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  }
}
