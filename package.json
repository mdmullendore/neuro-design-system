{
  "name": "neuro-design-system",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "npm run build --workspace=@neuro/design-system && vite",
    "build": "npm run build --workspace=@neuro/design-system && tsc -b && vite build",
    "lint": "oxlint",
    "lint:css": "stylelint \"src/**/*.scss\" \"packages/*/src/**/*.scss\"",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "preview": "vite preview",
    "storybook": "npm run build --workspace=@neuro/design-system && storybook dev -p 6006",
    "storybook:native": "npm run build --workspace=@neuro/design-system && storybook dev -p 6007 -c .storybook-native",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@neuro/design-system": "*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/addon-mcp": "^0.7.0",
    "@storybook/addon-vitest": "^10.5.2",
    "@storybook/react-native-web-vite": "^10.5.2",
    "@storybook/react-vite": "^10.5.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "react-native": "^0.86.0",
    "react-native-web": "^0.21.1",
    "remark-gfm": "^4.0.1",
    "sass": "^1.101.0",
    "storybook": "^10.5.2",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
